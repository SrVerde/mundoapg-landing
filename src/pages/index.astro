---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION } from '../consts';

// Configuración de perfil
const USERNAME = "Sr. Verde";
const BIO = "Creador de contenido y desarrollador. ¡Bienvenido a mi espacio digital!";
const AVATAR_URL = "/favicon.svg"; // Reemplaza por tu foto de perfil en public/

// Configuración de las tarjetas
const CARDS = [
	{
		name: "Discord",
		url: "https://discord.gg/invite-code",
		icon: "💬",
		color: "#5865F2",
		placeholderText: "Únete a nuestra comunidad. 120 miembros en línea.",
		buttonText: "Entrar al Servidor"
	},
	{
		name: "Ko-fi",
		url: "https://ko-fi.com/tu-usuario",
		icon: "☕",
		color: "#FF5E5B",
		placeholderText: "Apoya mi trabajo con una donación o compra un café.",
		buttonText: "Apoyar en Ko-fi"
	},
	{
		name: "Instagram",
		url: "https://instagram.com/tu-usuario",
		icon: "📸",
		color: "#E1306C",
		placeholderText: "Mira mis últimas publicaciones y reels diarios.",
		buttonText: "Ver Instagram"
	},
	{
		name: "Facebook",
		url: "https://facebook.com/tu-pagina",
		icon: "🔵",
		color: "#1877F2",
		placeholderText: "Sigue mis novedades, estados y eventos en Facebook.",
		buttonText: "Ir a Facebook"
	}
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${USERNAME} | Links & Socials`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main>
			<!-- Perfil -->
			<header class="profile">
				<img src={AVATAR_URL} alt={USERNAME} class="avatar" />
				<h1 class="name">{USERNAME}</h1>
				<p class="bio">{BIO}</p>
			</header>

			<!-- Grid 2x2 de Tarjetas -->
			<div class="grid-container">
				{CARDS.map(card => (
					<div class="card">
						<div class="card-header">
							<a href={card.url} target="_blank" rel="noopener noreferrer">
								<span style={`color: ${card.color};`}>{card.icon}</span>
								<span>{card.name}</span>
							</a>
							<span class="card-arrow">↗</span>
						</div>
						<div class="card-body">
							<div class="embed-placeholder">
								<p>{card.placeholderText}</p>
								<a href={card.url} target="_blank" rel="noopener noreferrer" class="embed-placeholder-btn" style={`background-color: ${card.color};`}>
									{card.buttonText}
								</a>
							</div>
						</div>
					</div>
				))}
			</div>

			<footer>
				<p>&copy; {new Date().getFullYear()} {USERNAME}. Hecho con Astro & Cloudflare Pages.</p>
			</footer>
		</main>
	</body>
</html>

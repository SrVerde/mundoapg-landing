---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION } from '../consts';
import DiscordIcon from '../components/icons/DiscordIcon.astro';
import KofiIcon from '../components/icons/KofiIcon.astro';
import TwitchIcon from '../components/icons/TwitchIcon.astro';
import BrandLogo from '../components/icons/BrandLogo.astro';

// Configuración de perfil
const USERNAME = "Sr. Verde";

// Configuración de URLs y Widgets (Reemplaza con tus datos)
const INSTAGRAM_URL = "https://instagram.com/tu-usuario";
const FACEBOOK_URL = "https://facebook.com/tu-pagina";
const TWITCH_URL = "https://twitch.tv/srverdoso";

const DISCORD_URL = "https://discord.gg/NhNTRxuZuu";
const DISCORD_WIDGET_ID = "690350889210609972";

const KOFI_URL = "https://ko-fi.com/mundoapg";
const KOFI_WIDGET_URL = "https://ko-fi.com/mundoapg/?hidefeed=true&widget=true&embed=true&preview=true";
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${USERNAME} | Links & Socials`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main>
			<!-- Logo de la Marca -->
			<header class="brand-header">
				<BrandLogo height={64} />
			</header>

			<!-- Botones de Enlace (Solo visibles en Móvil) -->
			<nav class="mobile-links-container">
				<a href={DISCORD_URL} target="_blank" rel="noopener noreferrer" class="mobile-link-button">
					<DiscordIcon size={20} />
					UNETE AL DISCORD
				</a>
				<a href={KOFI_URL} target="_blank" rel="noopener noreferrer" class="mobile-link-button">
					<KofiIcon size={20} />
					COMPRANOS UN CAFE
				</a>
				<a href="https://twitch.tv/srverdoso" target="_blank" rel="noopener noreferrer" class="mobile-link-button">
					<TwitchIcon size={20} />
					SRVERDOSO
				</a>
				<a href="https://twitch.tv/imcapitanzod" target="_blank" rel="noopener noreferrer" class="mobile-link-button">
					<TwitchIcon size={20} />
					IMCAPITANZOD
				</a>
			</nav>

			<!-- Contenedor Galería Asimétrica (3 Columnas en Desktop) -->
			<div class="gallery-container">
				<!-- Columna 1: Discord -->
				<div class="iframe-wrapper">
					<iframe 
						src={`https://discord.com/widget?id=${DISCORD_WIDGET_ID}&theme=dark`} 
						style="width: 100%; height: 580px; border: none; display: block; border-radius: 4px;" 
						allowtransparency="true" 
						sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
						title="Discord Widget">
					</iframe>
				</div>

				<!-- Columna 2: Ko-fi -->
				<div class="iframe-wrapper">
					<iframe 
						id="kofiframe" 
						src={KOFI_WIDGET_URL} 
						style="border: none; width: 100%; height: 580px; background: #f9f9f9; display: block; border-radius: 4px;" 
						title="mundoapg">
					</iframe>
				</div>

				<!-- Columna 3: Stack de Twitch (srverdoso y imcapitanzod) -->
				<div class="twitch-stack">
					<!-- Twitch: srverdoso -->
					<iframe 
						src={`https://player.twitch.tv/?channel=srverdoso&parent=localhost&parent=${Astro.url.hostname}`} 
						class="twitch-stack-iframe"
						allowfullscreen="true"
						title="Twitch srverdoso">
					</iframe>

					<!-- Twitch: imcapitanzod -->
					<iframe 
						src={`https://player.twitch.tv/?channel=imcapitanzod&parent=localhost&parent=${Astro.url.hostname}`} 
						class="twitch-stack-iframe"
						allowfullscreen="true"
						title="Twitch imcapitanzod">
					</iframe>
				</div>
			</div>

		</main>
	</body>
</html>
